{
  "name": "@newkrok/nape-js-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "npm run build -w @newkrok/nape-js",
    "test": "npm run test -w @newkrok/nape-js",
    "test:watch": "npm run test:watch -w @newkrok/nape-js",
    "lint": "npm run lint -w @newkrok/nape-js",
    "format": "npm run format -w @newkrok/nape-js",
    "format:check": "npm run format:check -w @newkrok/nape-js",
    "check:circular": "npm run check:circular -w @newkrok/nape-js",
    "benchmark": "npm run build && node benchmarks/run.mjs",
    "benchmark:json": "npm run build && node benchmarks/run.mjs --json",
    "benchmark:compare": "node benchmarks/compare.mjs",
    "benchmark:update-baseline": "npm run benchmark:json -- > benchmarks/baseline.json && echo 'baseline.json updated'",
    "build:docs": "npm run build && cp packages/nape-js/dist/index.js docs/nape-js.esm.js && rm -f docs/chunk-*.js && cp packages/nape-js/dist/chunk-*.js docs/ && node scripts/stamp-docs.mjs && npm run build:typedoc",
    "build:typedoc": "typedoc",
    "serve:docs": "npx serve docs",
    "dev:multiplayer": "npm run build && cp packages/nape-js/dist/index.js docs/nape-js.esm.js && rm -f docs/chunk-*.js && cp packages/nape-js/dist/chunk-*.js docs/ && npx concurrently -k -n docs,server -c cyan,green \"npx serve docs -l 5500\" \"cd server && PORT=3001 node index.js\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NewKrok/nape-js"
  },
  "author": "Istvan Krisztian Somoracz",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/NewKrok/nape-js/issues"
  },
  "homepage": "https://newkrok.github.io/nape-js/",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "madge": "^8.0.0",
    "prettier": "^3.8.3",
    "tsup": "^8.4.0",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.4"
  }
}
