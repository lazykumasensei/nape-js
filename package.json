{
  "name": "@newkrok/nape-js",
  "version": "3.13.6",
  "description": "Nape Physics Engine - Fully typed TypeScript 2D physics engine (rewrite of the Nape Haxe engine)",
  "type": "module",
  "sideEffects": [
    "dist/index.js",
    "dist/index.cjs",
    "src/core/engine.ts",
    "src/core/bootstrap.ts",
    "src/util/registerLists.ts",
    "src/geom/Vec2List.ts",
    "src/dynamics/ContactList.ts",
    "src/geom/GeomVertexIterator.ts",
    "src/native/util/ZPP_Vec2List.ts",
    "src/native/util/ZPP_ContactList.ts",
    "src/native/util/ZPP_PublicList.ts",
    "src/native/util/ZPP_MixVec2List.ts",
    "src/native/geom/ZPP_GeomVertexIterator.ts"
  ],
  "engines": {
    "node": ">=18"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./serialization": {
      "import": {
        "types": "./dist/serialization/index.d.ts",
        "default": "./dist/serialization/index.js"
      },
      "require": {
        "types": "./dist/serialization/index.d.cts",
        "default": "./dist/serialization/index.cjs"
      }
    },
    "./worker": {
      "import": {
        "types": "./dist/worker/index.d.ts",
        "default": "./dist/worker/index.js"
      },
      "require": {
        "types": "./dist/worker/index.d.cts",
        "default": "./dist/worker/index.cjs"
      }
    }
  },
  "llms": "https://newkrok.github.io/nape-js/llms.txt",
  "llmsFull": "https://newkrok.github.io/nape-js/llms-full.txt",
  "files": [
    "dist",
    "!dist/**/*.map",
    "llms.txt",
    "llms-full.txt"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "format": "prettier --write src/ tests/",
    "format:check": "prettier --check src/ tests/",
    "check:circular": "madge --circular --extensions ts src/ --json | node -e \"const d=JSON.parse(require('fs').readFileSync('/dev/stdin','utf8'));if(d.length>27){console.error('New circular dependencies detected: '+d.length+' (max 27)');process.exit(1)}else{console.log('Circular dependencies: '+d.length+'/27 (OK)')}\"",
    "benchmark": "npm run build && node benchmarks/run.mjs",
    "benchmark:json": "npm run build && node benchmarks/run.mjs --json",
    "benchmark:compare": "node benchmarks/compare.mjs",
    "benchmark:update-baseline": "npm run benchmark:json -- > benchmarks/baseline.json && echo 'baseline.json updated'",
    "build:docs": "npm run build && cp dist/index.js docs/nape-js.esm.js && rm -f docs/chunk-*.js && cp dist/chunk-*.js docs/ && node scripts/stamp-docs.mjs && npm run build:typedoc",
    "build:typedoc": "typedoc",
    "serve:docs": "npx serve docs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NewKrok/nape-js"
  },
  "keywords": [
    "nape",
    "physics",
    "2d",
    "typescript",
    "physics-engine",
    "collision-detection",
    "rigid-body"
  ],
  "author": "Istvan Krisztian Somoracz",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/NewKrok/nape-js/issues"
  },
  "homepage": "https://github.com/NewKrok/nape-js#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "madge": "^8.0.0",
    "prettier": "^3.8.1",
    "tsup": "^8.4.0",
    "typedoc": "^0.28.17",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.0.0"
  }
}
